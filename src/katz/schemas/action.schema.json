{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/expectedparrot/katz/main/src/katz/schemas/action.schema.json",
  "title": "Katz agent action",
  "type": "object",
  "required": [
    "id",
    "purpose",
    "command",
    "mutates_state",
    "requires_network",
    "requires_user_approval"
  ],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "purpose": {"type": "string", "minLength": 1},
    "command": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "mutates_state": {"type": "boolean"},
    "requires_network": {"type": "boolean"},
    "requires_user_approval": {"type": "boolean"},
    "reason": {"type": "string"}
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/expectedparrot/katz/main/src/katz/schemas/agent-status.schema.json",
  "title": "Katz agent status",
  "type": "object",
  "required": [
    "schema_version",
    "phase",
    "ready",
    "repository",
    "prerequisites",
    "review",
    "next_actions",
    "blockers"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "phase": {"type": "string"},
    "ready": {"type": "boolean"},
    "repository": {"type": "object"},
    "prerequisites": {"type": "object"},
    "review": {"type": ["object", "null"]},
    "next_actions": {
      "type": "array",
      "items": {"$ref": "action.schema.json"}
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {"type": "string"},
          "message": {"type": "string"}
        }
      }
    }
  }
}
